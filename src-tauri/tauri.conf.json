{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "leaf",
  "version": "0.1.0",
  "identifier": "com.leaf.ide",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Leaf",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 600,
        "titleBarStyle": "Transparent"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "dmg": {
        "windowSize": {
          "width": 540,
          "height": 380
        },
        "appPosition": {
          "x": 140,
          "y": 190
        },
        "applicationFolderPosition": {
          "x": 400,
          "y": 190
        }
      }
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY5NjRCRTI4NEY0QTQ0MEEKUldRS1JFcFBLTDVrK1p4MVNqa0F1Q0N6TE54bS9tTnNFOEw4ZzVzVlJLOUN1anRlMU9NdGhNSzkK",
      "endpoints": [
        "https://github.com/RatnaAnimesh/leaf/releases/latest/download/latest.json"
      ],
      "dialog": true
    }
  }
}
